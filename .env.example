IMAGE_BACKEND=auto
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=workflows/default.workflow_api.json
COMFYUI_TIMEOUT_SECONDS=180
COMFYUI_POSITIVE_NODE_ID=11
COMFYUI_NEGATIVE_NODE_ID=12
COMFYUI_SEED_NODE_ID=19
COMFYUI_WIDTH_NODE_ID=28
COMFYUI_HEIGHT_NODE_ID=28
COMFYUI_SAVE_PREFIX_NODE_ID=46
# 台本(LLM)生成の直前にComfyUIの/freeでVRAMを解放する（Ollama keep_alive=0等と併用）。
COMFYUI_FREE_BEFORE_LLM=false
LLM_PROVIDER=auto
# LM Studioなら :1234/v1、Ollamaなら http://127.0.0.1:11434/v1
LLM_BASE_URL=http://127.0.0.1:1234/v1
# Ollama利用時はモデル名を指定（例: qwen2.5:14b）
LLM_MODEL=
LLM_TIMEOUT_SECONDS=180
LLM_JSON_MODE=auto
LLM_MAX_CONTEXT_CHARS=24000
DATABASE_URL=sqlite:///data/local-doujin-studio.db
EXPORT_DIR=exports
KNOWLEDGE_DIR=data/knowledge
