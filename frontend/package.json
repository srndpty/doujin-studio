{
  "name": "local-doujin-studio-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "api:generate": "openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "size": "size-limit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run build && npm run size"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "konva": "^10.3.0",
    "lucide-react": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "js-yaml": "^4.1.2"
  },
  "size-limit": [
    {
      "name": "初期JavaScript",
      "path": "dist/assets/index-*.js",
      "limit": "300 KB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "size-limit": "^12.1.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
